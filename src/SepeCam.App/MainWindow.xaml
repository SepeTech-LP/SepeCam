<Window x:Class="SepeCam.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:vm="clr-namespace:SepeCam.App.ViewModels"
        Title="SepeCam"
        Width="1000" Height="640" MinWidth="780" MinHeight="520"
        Background="#F5F5F5"
        TextElement.Foreground="#1B1B1F"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
            <TextBlock Text="Camera:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="Refresh" Padding="14,5"
                    MinWidth="90" Margin="8,0,0,0" Command="{Binding RefreshCommand}"/>
            <ComboBox ItemsSource="{Binding Cameras}"
                      SelectedItem="{Binding SelectedCamera}"
                      DisplayMemberPath="FriendlyName"
                      MinHeight="28"
                      HorizontalContentAlignment="Stretch"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="2*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D7D7DA" BorderThickness="1"
                    CornerRadius="6" Padding="10">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="6,0,6,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Setting" Foreground="#6B6B70" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Value" Foreground="#6B6B70" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="#" Foreground="#6B6B70" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="3" Text="Auto" Foreground="#6B6B70" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Lock" Foreground="#6B6B70" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>
                    <Separator DockPanel.Dock="Top" Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Properties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PropertyViewModel}">
                                    <Grid Margin="6,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1"
                                                Minimum="{Binding Min}" Maximum="{Binding Max}"
                                                SmallChange="{Binding Step}" LargeChange="{Binding Step}"
                                                Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                IsEnabled="{Binding Auto, Converter={StaticResource InverseBoolConverter}}"
                                                Margin="6,0"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <CheckBox Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  IsChecked="{Binding Auto}"
                                                  IsEnabled="{Binding SupportsAuto}"
                                                  ToolTip="Camera controls value automatically"/>
                                        <CheckBox Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  IsChecked="{Binding Locked}"
                                                  ToolTip="Reapply this value on reconnect"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Background="Black" CornerRadius="6" Padding="2">
                <Grid>
                    <wfi:WindowsFormsHost x:Name="PreviewHost" Visibility="Collapsed"/>
                    <TextBlock x:Name="PreviewOverlay"
                               Text="Preview disabled"
                               Foreground="#9A9A9A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#D7D7DA" BorderThickness="1"
                CornerRadius="6" Padding="10" Margin="0,10,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <CheckBox Content="Preview" IsChecked="{Binding PreviewEnabled}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Show in Start Menu" IsChecked="{Binding ShowInStartMenu}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Start with Windows" IsChecked="{Binding LaunchOnStartup}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Save Profile" Command="{Binding SaveAllCommand}" Padding="12,5" Margin="0,0,6,0"/>
                    <Button Content="Lock All" Command="{Binding LockAllCommand}" Padding="12,5" Margin="0,0,6,0"/>
                    <Button Content="Unlock All" Command="{Binding UnlockAllCommand}" Padding="12,5" Margin="0,0,6,0"/>
                    <Button Content="Reset Defaults" Command="{Binding ResetAllCommand}" Padding="12,5" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="#6B6B70"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
